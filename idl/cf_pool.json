  "types": [
    {
      "name": "InvoiceAccount",
      "docs": [
        "Invoice submitted for factoring.",
        "PDA: [INVOICE_SEED, pool, invoice_id (16 bytes UUID)]"
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "pool",
            "type": "pubkey"
          },
          {
            "name": "carrier_wallet",
            "docs": [
              "Carrier's wallet (must be KYC-approved in cf-kyc)"
            ],
            "type": "pubkey"
          },
          {
            "name": "carrier_usdc",
            "docs": [
              "Carrier's USDC token account — receives the advance"
            ],
            "type": "pubkey"
          },
          {
            "name": "invoice_id",
            "docs": [
              "16-byte UUID from CargoFi Dispatch (matches Supabase load id)"
            ],
            "type": {
              "array": [
                "u8",
                16
              ]
            }
          },
          {
            "name": "gross_amount",
            "docs": [
              "Full invoice value in USDC (6 decimals)"
            ],
            "type": "u64"
          },
          {
            "name": "advance_amount",
            "docs": [
              "Advance sent to carrier = gross * advance_rate_bps / 10_000"
            ],
            "type": "u64"
          },
          {
            "name": "fee_amount",
            "docs": [
              "Fee retained by pool = gross - advance"
            ],
            "type": "u64"
          },
          {
            "name": "status",
            "type": {
              "defined": {
